# ===================================
# OIDC Authentication (REQUIRED)
# ===================================
OIDC_ISSUER=https://login.alloy.ch/realms/a2a
OIDC_CLIENT_ID=web-client

# ===================================
# Keycloak Admin API
# ===================================
# Enable Keycloak group synchronization for MCP Gateway authorization
# All environments use the same realm with prefixed group names:
# - Local: KEYCLOAK_GROUP_NAME_PREFIX=local-
# - Dev: KEYCLOAK_GROUP_NAME_PREFIX=dev-
# - Stg: KEYCLOAK_GROUP_NAME_PREFIX=stg-
# - Prod: KEYCLOAK_GROUP_NAME_PREFIX=prod-
# Admin client must have realm-management roles: manage-users, manage-groups, manage-clients
KEYCLOAK_ADMIN_CLIENT_ID=nannos-admin
KEYCLOAK_GROUP_NAME_PREFIX=local-
KEYCLOAK_ADMIN_CLIENT_SECRET=the-secret-value-here

# ===================================
# Orchestrator Configuration
# ===================================
ORCHESTRATOR_CLIENT_ID=orchestrator
ORCHESTRATOR_BASE_DOMAIN=localhost:10001
ORCHESTRATOR_ENVIRONMENT=local

# ===================================
# Azure OpenAI Configuration
# ===================================
# NOTE: These values are used for direct OpenAI calls in playground-backend.
# Orchestrator auto-determines these based on model type.
OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_MODEL_NAME=gpt-4o
AZURE_OPENAI_CHAT_DEPLOYMENT=chatgpt-4o
AZURE_OPENAI_ENDPOINT=https://rcplus-alloy-eu-prod.openai.azure.com

# ===================================
# Bedrock Configuration: https://docs.aws.amazon.com/bedrock/latest/userguide/inference-profiles-support.html
# ===================================
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
# BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-5-20251101-v1:0

# ===================================
# Checkpoint Configuration
# ===================================
CHECKPOINT_DYNAMODB_TABLE_NAME=dev-nannos-infrastructure-agents-langgraph-checkpoints
CHECKPOINT_S3_BUCKET_NAME=dev-nannos-infrastructure-agents-orchestrator-checkpoints
CHECKPOINT_TTL_DAYS=14
CHECKPOINT_COMPRESSION_ENABLED=true

# ===================================
# Observability & Logging
# ===================================
LOG_LEVEL=INFO
LOG_MODE=JSON

# ===================================
# JWT Session Configuration
# ===================================
JWT_SESSION_EXPIRY_MINUTES=15
JWT_SECRET_KEY=your-secret-key-here


# ==============================================================================
# Session Cookie Configuration
# ==============================================================================
SESSION_COOKIE_SECURE=false  # must be true in production with HTTPS


# ===============================
# User Service Configuration
# ===============================
DYNAMODB_USERS_TABLE=dev-nannos-infrastructure-agents-users

# ===================================
# PostgreSQL Database Configuration
# ===================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=playground
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_SCHEMA=playground
