# Agent Runner Configuration
# Internal execution service for scheduled automated sub-agent jobs

# Server Configuration
HOST=0.0.0.0
PORT=5005
AGENT_BASE_URL=http://localhost:5005

# OIDC Authentication
# Uses the orchestrator Keycloak client (no dedicated agent-runner client exists).
# This client is used for both inbound JWT validation and outbound token exchange
# (SmartTokenInterceptor) when calling remote A2A agents.
OIDC_ISSUER=https://login.p.nannos.rcplus.io/realms/nannos
OIDC_CLIENT_ID=orchestrator
# Client ID of the scheduler service (playground-backend) — used to validate azp claim
SCHEDULER_SERVICE_CLIENT_ID=agent-console

# Playground Backend (for fetching sub-agent configs)
PLAYGROUND_BACKEND_URL=http://localhost:5001

# MCP Gateway (for tool execution)
MCP_GATEWAY_URL=https://alloych.gatana.ai/mcp
MCP_TIMEOUT_SECONDS=300

# AWS Bedrock Configuration
AWS_BEDROCK_REGION=eu-central-1
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0

# Checkpointer Configuration (DynamoDB + optional S3 offloading)
CHECKPOINT_DYNAMODB_TABLE_NAME=dev-nannos-infrastructure-agents-langgraph-checkpoints
CHECKPOINT_S3_BUCKET_NAME=dev-nannos-infrastructure-agents-orchestrator-checkpoints
CHECKPOINT_AWS_REGION=eu-central-1
CHECKPOINT_TTL_DAYS=14
CHECKPOINT_COMPRESSION_ENABLED=true

# LangSmith Distributed Tracing
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_PROJECT=dev-nannos-agent-framework

# Document Store (PostgreSQL + pgvector) — shared with orchestrator
# Leave POSTGRES_HOST empty to disable the document store
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=playground
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_SCHEMA=playground
DOCUMENT_STORE_S3_BUCKET=dev-nannos-infrastructure-agents-files

# GCP Configuration (for Gemini models)
GCP_PROJECT_ID=rcplus-alloy-gcp
GCP_LOCATION=global
