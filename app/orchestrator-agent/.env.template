# ===================================
# OIDC Authentication (REQUIRED)
# ===================================
OIDC_ISSUER=https://login.p.nannos.rcplus.io/realms/nannos
OIDC_CLIENT_ID=orchestrator

# ===================================
# Playground Backend Configuration
# ===================================
PLAYGROUND_BACKEND_URL=http://localhost:5001
PLAYGROUND_FRONTEND_URL=http://localhost:5173

# ===================================
# Azure OpenAI Configuration
# ===================================
# NOTE: API_VERSION, CHAT_MODEL_NAME, and CHAT_DEPLOYMENT are auto-determined by model type:
#   gpt-4o        -> api_version=2024-08-01-preview, deployment=chatgpt-4o
#   gpt-4o-mini  -> api_version=2025-01-01-preview, deployment=gpt-4o-mini
# Only AZURE_OPENAI_ENDPOINT is required:
AZURE_OPENAI_ENDPOINT=https://rcplus-alloy-eu-prod.openai.azure.com

# ===================================
# Bedrock Configuration: https://docs.aws.amazon.com/bedrock/latest/userguide/inference-profiles-support.html
# ===================================
# NOTE: BEDROCK_MODEL_ID is auto-determined by model type:
#   claude-sonnet-4.5 -> us.anthropic.claude-sonnet-4-20250514-v1:0
#   claude-haiku-4-5  -> global.anthropic.claude-haiku-4-5-20251001-v1:0
# No configuration needed - AWS credentials from environment are sufficient.

# Bedrock Client Timeout Configuration
# Increase these for long-running Claude responses (default: read_timeout=300s, connect_timeout=10s)
# BEDROCK_READ_TIMEOUT=300
# BEDROCK_CONNECT_TIMEOUT=10
# BEDROCK_MAX_RETRY_ATTEMPTS=3
# BEDROCK_RETRY_MODE=adaptive

# ===================================
# Checkpoint Configuration
# ===================================
CHECKPOINT_DYNAMODB_TABLE_NAME=dev-nannos-infrastructure-agents-langgraph-checkpoints
CHECKPOINT_S3_BUCKET_NAME=dev-nannos-infrastructure-agents-orchestrator-checkpoints
CHECKPOINT_TTL_DAYS=14
CHECKPOINT_COMPRESSION_ENABLED=true

# ===================================
# Extended Thinking Configuration
# ===================================
# Enable extended thinking for orchestrator's own reasoning (NOT sub-agents)
# Sub-agents have their own thinking configuration in playground-backend
ORCHESTRATOR_ENABLE_THINKING=true
# Thinking depth level: minimal (1024 tokens), low (4096), medium (10000), high (16000)
# Only applies to Claude Sonnet 4.5, 4.6 and Gemini models
ORCHESTRATOR_THINKING_LEVEL=low

# ===================================
# MCP Gateway Configuration
# ===================================
MCP_GATEWAY_URL=https://alloych.gatana.ai/mcp
MCP_GATEWAY_CLIENT_ID=gatana

# ===================================
# A2A Client Timeout Configuration
# ===================================
# Timeouts for Agent-to-Agent (A2A) HTTP communication with sub-agents
# Increase A2A_TIMEOUT_READ for heavy operations (e.g., campaign_proposal can take 5-10 minutes)
# timeouts in seconds
A2A_TIMEOUT_CONNECT=10.0
A2A_TIMEOUT_READ=600.0
A2A_TIMEOUT_WRITE=10.0
A2A_TIMEOUT_POOL=5.0

# ===================================
# Observability & Logging
# ===================================
LOG_LEVEL=DEBUG
LOG_MODE=JSON

# ===================================
# LangSmith Configuration
# ===================================
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_PROJECT=dev-nannos-agent-framework

# ===============================
# User Service Configuration
# ===============================
DYNAMODB_USERS_TABLE=dev-nannos-infrastructure-agents-users

# ===================================
# PostgreSQL Configuration (Document Store)
# ===================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=playground
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_SCHEMA=playground

# ===================================
# Document Store S3 Configuration
# ===================================
# Shared bucket with playground-backend for file storage
# Uses docstore/exports/ prefix for temporary download artifacts (7-day lifecycle)
# Presigned URLs expire in 24 hours, S3 cleanup after 7 days
DOCUMENT_STORE_S3_BUCKET=dev-nannos-infrastructure-agents-files

# ===================================
# Google Cloud Configuration
# ===================================
# Vertex AI Configuration (for Gemini models)
GCP_PROJECT_ID=rcplus-alloy-gcp
GCP_LOCATION=global
# NOTE: GCP_KEY must be wrapped in single quotes to preserve JSON format
# Example: GCP_KEY='{"type":"service_account",...}'
GCP_KEY='{}'
# ===================================
# File Analyzer Sub-Agent Configuration
# ===================================
# Model for file analysis (images, PDFs, text, audio, video)
# Default: gemini-3-flash-preview (true multimodal with native audio/video support)
# Alternatives: gemini-3-pro-preview, gpt-4o, gpt-4o-mini, claude-sonnet-4.5
# Note: Only Gemini and gpt-4o models support native audio/video analysis
# FILE_ANALYZER_MODEL=gemini-3-flash-preview
