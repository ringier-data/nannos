# ===================================
# OIDC Authentication (REQUIRED)
# ===================================
OIDC_ISSUER=https://login.alloy.ch/realms/a2a
OIDC_CLIENT_ID=orchestrator

# ===================================
# Azure OpenAI Configuration
# ===================================
OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_MODEL_NAME=gpt-4o
AZURE_OPENAI_CHAT_DEPLOYMENT=chatgpt-4o
AZURE_OPENAI_ENDPOINT=https://rcplus-alloy-eu-prod.openai.azure.com

# ===================================
# Bedrock Configuration: https://docs.aws.amazon.com/bedrock/latest/userguide/inference-profiles-support.html
# ===================================
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
# BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-5-20251101-v1:0

# ===================================
# Checkpoint Configuration
# ===================================
CHECKPOINT_DYNAMODB_TABLE_NAME=dev-alloy-infrastructure-agents-orchestrator-checkpoints
CHECKPOINT_S3_BUCKET_NAME=dev-alloy-infrastructure-agents-orchestrator-checkpoints
CHECKPOINT_TTL_DAYS=14
CHECKPOINT_COMPRESSION_ENABLED=true

# ===================================
# Observability & Logging
# ===================================
LOG_LEVEL=INFO
LOG_MODE=JSON

# ===================================
# LangSmith Configuration
# ===================================
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_PROJECT=alloy-agent-framework-dev

# ===================================
# JWT Session Configuration
# ===================================
JWT_SESSION_EXPIRY_MINUTES=15
JWT_SECRET_KEY=your-secret-key-here


# ==============================================================================
# Session Cookie Configuration
# ==============================================================================
SESSION_COOKIE_SECURE=false  # must be true in production with HTTPS


# ===============================
# User Service Configuration
# ===============================
DYNAMODB_USERS_TABLE=dev-alloy-infrastructure-agents-users

# ===================================
# Secret Keys
# ===================================
OIDC_CLIENT_SECRET=
JWT_SECRET_KEY=
LANGSMITH_API_KEY=
AZURE_OPENAI_API_KEY=
