# Logging Configuration
LOG_LEVEL=DEBUG

# OIDC Authentication
OIDC_ISSUER=https://login.p.nannos.rcplus.io/realms/nannos
ORCHESTRATOR_CLIENT_ID=orchestrator
AGENT_CLIENT_ID=agent-creator

# Agent Identity (for X-Agent-ID header and created_by_agent_id)
AGENT_ID=1

# Playground Backend Integration
PLAYGROUND_BACKEND_URL=http://localhost:5001
PLAYGROUND_FRONTEND_URL=http://localhost:5173

# AWS Bedrock Configuration
AWS_BEDROCK_REGION=eu-central-1
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0

# Bedrock Client Timeout Configuration
# Increase these for long-running Claude responses (default: read_timeout=300s, connect_timeout=10s)
# BEDROCK_READ_TIMEOUT=300
# BEDROCK_CONNECT_TIMEOUT=10
# BEDROCK_MAX_RETRY_ATTEMPTS=3
# BEDROCK_RETRY_MODE=adaptive

# Checkpointer Configuration
CHECKPOINT_DYNAMODB_TABLE_NAME=dev-nannos-infrastructure-agents-langgraph-checkpoints
CHECKPOINT_S3_BUCKET_NAME=dev-nannos-infrastructure-agents-orchestrator-checkpoints
CHECKPOINT_AWS_REGION=eu-central-1
CHECKPOINT_TTL_DAYS=14
CHECKPOINT_COMPRESSION_ENABLED=true

# Agent Base URL (for production deployment)
AGENT_BASE_URL=http://localhost:8080
OIDC_CLIENT_ID=agent-creator
OIDC_CLIENT_SECRET=
OIDC_ISSUER=https://login.p.nannos.rcplus.io/realms/nannos

# ===================================
# LangSmith Configuration
# ===================================
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_PROJECT=dev-nannos-agent-framework
