LOCAL_DB_PORT := "4705"
LOCAL_DB_DATA := ".local-db-data"

default:
  @just -l
# Start local postgres (vanilla, with persistent data)
local-db:
  #!/usr/bin/env bash
  set -e
  mkdir -p {{LOCAL_DB_DATA}}
  
  # Check if postgres is already running on the port
  if docker ps --filter publish={{LOCAL_DB_PORT}} --format '{{{{.Names}}}}' | grep -q .; then
    echo "✓ PostgreSQL already running on port {{LOCAL_DB_PORT}}"
    exit 0
  fi
  
  # Stop any stopped containers using our volume
  docker ps -aq --filter name=nannos-local-db | xargs -r docker rm -f 2>/dev/null || true
  
  echo "Starting PostgreSQL 18 on port {{LOCAL_DB_PORT}}..."
  docker run -d \
    --name nannos-local-db \
    -p {{LOCAL_DB_PORT}}:5432 \
    -v "$(pwd)/{{LOCAL_DB_DATA}}:/var/lib/postgresql" \
    -e POSTGRES_USER=postgres \
    -e POSTGRES_PASSWORD=password \
    -e POSTGRES_DB=nannos \
    postgres:18
  
  echo "Waiting for PostgreSQL to be ready..."
  for i in $(seq 1 30); do
    if ! docker inspect -f '{{{{.State.Running}}}}' nannos-local-db 2>/dev/null | grep -q true; then
      echo "✗ Container exited unexpectedly. Logs:"
      docker logs --tail 100 nannos-local-db 2>&1 || true
      exit 1
    fi
    if docker exec nannos-local-db pg_isready -U postgres > /dev/null 2>&1; then
      echo "✓ PostgreSQL is ready"
      exit 0
    fi
    sleep 0.5
  done
  echo "✗ Timed out waiting for PostgreSQL"
  exit 1

# Build the migration image
build-migrations:
  docker build -t nannos-client-email-migrations:latest sqlmigrations

# Run migrations against local db
migrate: local-db build-migrations
  #!/usr/bin/env bash
  set -e
  echo "Running migrations..."
  docker run --rm \
    --network host \
    -e PGHOST=127.0.0.1 \
    -e PGPORT={{LOCAL_DB_PORT}} \
    -e PGUSER=postgres \
    -e PGPASSWORD=password \
    -e PGDATABASE=nannos \
    -e PGSCHEMA=nannos \
    -e APP_USERNAME=app \
    -e APP_PASSWORD=apppassword \
    -e RAMBLER_SSLMODE=disable \
    nannos-client-email-migrations:latest
  echo "✓ Migrations complete"

# Reset local database (deletes all data)
reset-db:
  #!/usr/bin/env bash
  set -e
  docker ps -q --filter name=nannos-local-db | xargs -r docker stop
  docker ps -aq --filter name=nannos-local-db | xargs -r docker rm
  rm -rf {{LOCAL_DB_DATA}}
  echo "✓ Database data cleared. Run 'just local-db' to start fresh."

start: migrate
  #!/usr/bin/env bash
  set -e
  if [ ! -f .env ]; then
    cp .env.example .env
    echo "Created .env from .env.example"
    echo "Please fill out the required values in .env"
    read -p "Press Enter to continue..."
  fi
  ./wait-for-postgres.sh postgres:password@localhost:{{LOCAL_DB_PORT}}/nannos
  npm run dev

# Connect to local database with psql
psql: local-db
  PGPASSWORD=password PGOPTIONS='-c search_path=nannos,public' psql -h localhost -p {{LOCAL_DB_PORT}} -U postgres -d nannos
