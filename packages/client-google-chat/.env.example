# Environment
ENVIRONMENT=local

GOOGLE_CHAT_TOKEN_EXPECTED_AUDIENCE=https://chat-backend/api/v1/chat/events

# Google Chat Configuration
GCP_CHAT_PROJECTS=[{"name": "nannos-dev", "google_chat_app_id": "your-project-number"}]

# GCP Service Account credentials (inline JSON)
GCP_SA_JSON_KEY_NANNOS_DEV={"type":"service_account","project_id":"..."}

# App Configuration
BASE_URL=http://localhost:3000
APP_PORT=3000
LOG_LEVEL=debug

# PostgreSQL Configuration
STORAGE_PROVIDER=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=4701
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=nannos
POSTGRES_USE_SSL=false
# POSTGRES_SSL_CA=/path/to/ca-cert.pem

# Installation notification secrets
# Backend for per-installation A2A notification secrets.
#   db      (default) — persisted via the storage provider; cloud-agnostic, no extra infra.
#   aws-ssm           — AWS SSM Parameter Store (requires AWS credentials).
INSTALLATION_SECRET_PROVIDER=db
# INSTALLATION_SECRET_SSM_PREFIX=/nannos/<env>/client-google-chat/installation-secrets  # only for aws-ssm

# AWS Configuration (only needed when using AWS-backed providers, e.g. S3 file
# uploads or INSTALLATION_SECRET_PROVIDER=aws-ssm)
AWS_REGION=eu-central-1
FILES_S3_BUCKET=dev-nannos-infrastructure-agents-files

# OIDC Configuration
OIDC_ISSUER_URL=https://your-oidc-issuer.com
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
OIDC_ORCHESTRATOR_AUDIENCE=orchestrator

# A2A Server Configuration
A2A_SERVER_URL=https://your-a2a-server.com/api
A2A_SERVER_TIMEOUT=30000
