# ===================================
# OIDC Authentication (REQUIRED)
# ===================================
OIDC_ISSUER=https://login.p.nannos.rcplus.io/realms/nannos
OIDC_CLIENT_ID=agent-console

# ===================================
# Keycloak Admin API
# ===================================
# Enable Keycloak group synchronization for MCP Gateway authorization
# All environments use the same realm with prefixed group names:
# - Local: KEYCLOAK_GROUP_NAME_PREFIX=local-
# - Dev: KEYCLOAK_GROUP_NAME_PREFIX=dev-
# - Stg: KEYCLOAK_GROUP_NAME_PREFIX=stg-
# - Prod: KEYCLOAK_GROUP_NAME_PREFIX=prod-
# Admin client must have realm-management roles: manage-users, manage-groups, manage-clients
KEYCLOAK_ADMIN_CLIENT_ID=nannos-admin
KEYCLOAK_GROUP_NAME_PREFIX=local-
KEYCLOAK_ADMIN_CLIENT_SECRET=the-secret-value-here

# ===================================
# Orchestrator Configuration
# ===================================
ORCHESTRATOR_CLIENT_ID=orchestrator
ORCHESTRATOR_BASE_DOMAIN=localhost:10001
ORCHESTRATOR_ENVIRONMENT=local

# ===================================
# Remote Agent URLs (system-owned agents)
# ===================================
# These are synced to the DB on startup for seeded remote agents.
# start-dev.sh populates them automatically depending on --voice-agent / --agent-creator flags.
VOICE_AGENT_URL=http://localhost:8002
AGENT_CREATOR_URL=http://localhost:8080

# ===================================
# Azure OpenAI Configuration
# ===================================
# NOTE: These values are used for direct OpenAI calls in agent-console backend.
# Orchestrator auto-determines these based on model type.
OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_MODEL_NAME=gpt-4o
AZURE_OPENAI_CHAT_DEPLOYMENT=chatgpt-4o
AZURE_OPENAI_ENDPOINT=https://rcplus-alloy-eu-prod.openai.azure.com

# ===================================
# Bedrock Configuration: https://docs.aws.amazon.com/bedrock/latest/userguide/inference-profiles-support.html
# ===================================
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
# BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-5-20251101-v1:0

# ===================================
# Checkpoint Configuration
# ===================================
CHECKPOINT_DYNAMODB_TABLE_NAME=dev-nannos-infrastructure-agents-langgraph-checkpoints
CHECKPOINT_S3_BUCKET_NAME=dev-nannos-infrastructure-agents-orchestrator-checkpoints
CHECKPOINT_TTL_DAYS=14
CHECKPOINT_COMPRESSION_ENABLED=true

# ===================================
# File Storage Configuration
# ===================================
# Object storage backend selection: 's3' (default), 's3-compatible', or 'local'
# - s3: AWS S3 (production)
# - s3-compatible: MinIO, DigitalOcean Spaces, Wasabi, etc.
# - local: File system (development)
OBJECT_STORAGE_TYPE=s3

# S3 bucket for user-uploaded files (images, audio recordings, documents)
# Shared with orchestrator document store with prefix-based organization:
# - uploads/ (default): Chat conversation attachments (365-day lifecycle)
# - docstore/exports/: Orchestrator temporary download artifacts (7-day lifecycle)
# - temp/: Ephemeral processing files (7-day lifecycle)
FILES_S3_BUCKET=dev-nannos-infrastructure-agents-files
FILES_PRESIGNED_TTL_SECONDS=3600
FILES_S3_PREFIX=

# S3-compatible endpoint (optional, for MinIO, DigitalOcean Spaces, etc.)
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin

# Local storage path (for OBJECT_STORAGE_TYPE=local, development only)
# LOCAL_STORAGE_PATH=./local-storage

# ===================================
# MCP Gateway Configuration
# ===================================
MCP_GATEWAY_URL=https://alloych.gatana.ai/mcp
MCP_GATEWAY_CLIENT_ID=gatana

# ===================================
# Observability & Logging
# ===================================
LOG_LEVEL=INFO
LOG_MODE=JSON

# ===================================
# PostgreSQL Database Configuration
# ===================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=console
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_SCHEMA=console

# Set to any value to use in-memory stores instead of PostgreSQL
# for sessions, conversations, and messages (local dev without PG)
# USE_IN_MEMORY_STORE=1

# ===================================
# Twilio Verify (Phone Verification)
# ===================================
# Leave blank to disable phone number verification
TWILIO_ACCOUNT_SID=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_VERIFY_API_KEY=
TWILIO_VERIFY_API_SECRET=

# ===================================
# Catalog Configuration (Google Drive Sync + S3 Vectors)
# ===================================
CATALOG_VECTOR_BUCKET_NAME=dev-nannos-infrastructure-agents-catalog-vectors
CATALOG_THUMBNAILS_S3_BUCKET=dev-nannos-infrastructure-agents-catalog-thumbnails
CATALOG_VECTOR_STORE_BACKEND=s3_vectors
CATALOG_SUMMARIZATION_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
CATALOG_AUTO_SYNC_ENABLED=true
CATALOG_SYNC_INTERVAL_SECONDS=86400
CATALOG_SYNC_TICK_INTERVAL_SECONDS=300
CATALOG_SYNC_MAX_CONCURRENT=3
# Google OAuth credentials for Drive sync (leave blank to disable)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5001/api/v1/catalogs/connect/callback

# GCP credentials for Gemini Embedding 2 (catalog embeddings)
# NOTE: GCP_KEY must be wrapped in single quotes to preserve JSON format
# Example: GCP_KEY='{"type":"service_account",...}'
GCP_KEY='{}'
GCP_PROJECT_ID=rcplus-alloy-gcp

# ===================================
# Frontend Runtime Configuration
# ===================================
# Served to the frontend SPA via GET /api/v1/config
LANGSMITH_ORGANIZATION_ID=
LANGSMITH_PROJECT_ID=
AUTO_APPROVE_MAX_SYSTEM_PROMPT_LENGTH=500
AUTO_APPROVE_MAX_MCP_TOOLS_COUNT=3
