# ── Google Vertex AI ──────────────────────────────────────────────────────────
# Service account key JSON (entire JSON blob, same as used by orchestrator-agent)
GCP_KEY=

# GCP project that has the Vertex AI API enabled
GCP_PROJECT_ID=rcplus-alloy-gcp

# Region — Gemini Live is available in us-central1 and europe-west1 (not "global")
GCP_LOCATION=europe-west1

# Model — defaults to gemini-2.5-flash-native-audio-preview-12-2025
# GEMINI_MODEL_ID=gemini-2.5-flash-native-audio-preview-12-2025

# Built-in voice name (Puck | Charon | Kore | Fenrir | Aoede | Leda | Orus | Zephyr)
# GEMINI_VOICE=Kore

# ── Server ────────────────────────────────────────────────────────────────────
HOST=localhost
PORT=8002
# LOG_LEVEL=INFO

# ── A2A Server Configuration ──────────────────────────────────────────────────
VOICE_AGENT_BASE_URL=http://localhost:8002

# ── OIDC Authentication (for A2A server / scheduler sub-agent use) ─────────────
# Required: enables JWT validation so user context (sub, name, email) is available.

OIDC_ISSUER=https://login.p.nannos.rcplus.io/realms/nannos
# Optional: restrict accepted azp claim. Leave unset to accept any Keycloak client
# (needed because the orchestrator forwards the user's agent-console JWT directly,
#  while agent-runner sends an exchanged token with azp=orchestrator).
# ORCHESTRATOR_CLIENT_ID=orchestrator

# ── Playground Backend (for sub-agent config fetch) ───────────────────────────
PLAYGROUND_BACKEND_URL=http://localhost:5001

# ── MCP / Gatana Gateway ─────────────────────────────────────────────────────────
# Streamable-HTTP MCP gateway URL. When set, the voice agent connects to
# Gatana and registers tools for the Gemini Live session.
# The user's Bearer token is forwarded as the Authorization header.
# Leave empty to run without MCP tools.
MCP_GATEWAY_URL=https://alloych.gatana.ai/mcp
# Timeout in seconds for both HTTP handshake and SSE read operations.
MCP_TIMEOUT_SECONDS=60

# Local-dev only: static Bearer token used by _fetch_sub_agent_config when the
# incoming A2A request carries no access token (e.g. scheduler via agent-runner
# in dev mode without OIDC).  Obtain with:
#
#   curl -s -X POST http://localhost:8080/realms/nannos/protocol/openid-connect/token \
#     -d "client_id=nannos-app&grant_type=password&username=<user>&password=<pw>" \
#     | jq -r .access_token
#

# ── Call timeout (A2A phone-call path) ────────────────────────────────────────
# How long to wait (seconds) for a Twilio call to complete before timing out.
CALL_TIMEOUT_SECONDS=600

# ── LangSmith Distributed Tracing ─────────────────────────────────────────────
# LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_PROJECT=dev-nannos-agent-framework

# ── Twilio (optional — only needed for phone call integration) ────────────────
# Required for OUTBOUND calls (POST /twilio/call):
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
#
# For non-US regions (e.g., Ireland), specify region and edge:
# TWILIO_REGION=dublin
# TWILIO_EDGE=dublin
#
# Public URL of this server (required for outbound calls so Twilio can reach the
# TwiML webhook; auto-detected from request Host header for inbound calls):
TWILIO_EDGE=dublin
TWILIO_PHONE_NUMBER=+358454917751
TWILIO_REGION=ie1
OIDC_CLIENT_ID=voice-agent
