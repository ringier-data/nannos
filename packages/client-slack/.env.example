# Environment
ENVIRONMENT=local

# Slack App Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret
SLACK_STATE_SECRET=your-state-secret

# App Configuration
BASE_URL=http://localhost:3000
SLACK_APP_PORT=3000
LOG_LEVEL=debug

# Storage Provider Configuration
# Options: 'dynamodb' or 'postgres'
STORAGE_PROVIDER=postgres

# PostgreSQL Configuration (when STORAGE_PROVIDER=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=4700
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=nannos
POSTGRES_USE_SSL=false
# POSTGRES_SSL_CA=/path/to/ca-cert.pem

# Installation notification secrets
# Backend for per-installation A2A notification secrets.
#   db      (default) — persisted via the storage provider; cloud-agnostic, no extra infra.
#   aws-ssm           — AWS SSM Parameter Store (requires AWS credentials).
INSTALLATION_SECRET_PROVIDER=db
# INSTALLATION_SECRET_SSM_PREFIX=/nannos/<env>/client-slack/installation-secrets  # only for aws-ssm

# AWS Configuration (only needed when using AWS-backed providers, e.g. S3 file
# uploads or INSTALLATION_SECRET_PROVIDER=aws-ssm)
AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
FILES_S3_BUCKET=dev-nannos-infrastructure-agents-files

# OIDC Configuration
OIDC_ISSUER_URL=https://your-oidc-issuer.com
OIDC_CLIENT_ID=your-oidc-client-id
# Provide the secret directly via env (cloud-agnostic). Deployments can project
# their secret store (k8s/Docker secrets, Vault, AWS External Secrets, ...) here.
OIDC_CLIENT_SECRET=your-oidc-client-secret
# Opt-in AWS fallback: fetch from SSM when OIDC_CLIENT_SECRET is unset.
# OIDC_CLIENT_SECRET_SSM_KEY=/path/to/ssm/key
OIDC_ORCHESTRATOR_AUDIENCE=orchestrator

# A2A Server Configuration
A2A_SERVER_URL=https://your-a2a-server.com/api
A2A_SERVER_TIMEOUT=30000
