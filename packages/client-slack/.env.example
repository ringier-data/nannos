# Environment
ENVIRONMENT=local

# Slack App Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret
SLACK_STATE_SECRET=your-state-secret

# App Configuration
BASE_URL=http://localhost:3000
SLACK_APP_PORT=3000
LOG_LEVEL=debug

# Storage Provider Configuration
# Options: 'dynamodb' or 'postgres'
STORAGE_PROVIDER=postgres

# PostgreSQL Configuration (when STORAGE_PROVIDER=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=4700
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=nannos
POSTGRES_USE_SSL=false
# POSTGRES_SSL_CA=/path/to/ca-cert.pem

# AWS Configuration
AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
FILES_S3_BUCKET=dev-nannos-infrastructure-agents-files

# OIDC Configuration
OIDC_ISSUER_URL=https://your-oidc-issuer.com
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
# Or use SSM: OIDC_CLIENT_SECRET_SSM_KEY=/path/to/ssm/key
OIDC_ORCHESTRATOR_AUDIENCE=orchestrator

# A2A Server Configuration
A2A_SERVER_URL=https://your-a2a-server.com/api
A2A_SERVER_TIMEOUT=30000
