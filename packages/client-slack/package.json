  "scripts": {
    "build": "rm -rf dist && npx tsc",
    "test": "NODE_ENV=development NODE_OPTIONS=\"--no-warnings --experimental-vm-modules\" npx jest --collectCoverage --detectOpenHandles --errorOnDeprecated --logHeapUsage --forceExit --runInBand --passWithNoTests",
