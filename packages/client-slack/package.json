    "test:coverage": "NODE_ENV=development NODE_OPTIONS=\"--no-warnings --experimental-vm-modules\" npx jest --collectCoverage",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "start": "rm -rf dist && npx tsc && node --env-file=.env dist/src/index.js",
    "dev": "NODE_ENV=local tsx --env-file .env --watch src/index.ts"
