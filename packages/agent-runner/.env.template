# Agent Runner Configuration
# Internal execution service for scheduled automated sub-agent jobs

# Server Configuration
HOST=0.0.0.0
PORT=5005
AGENT_BASE_URL=http://localhost:5005

# OIDC Authentication
# Uses the dedicated agent-runner Keycloak client for both inbound JWT
# validation and outbound token exchange (SmartTokenInterceptor) when
# calling remote A2A agents.
OIDC_ISSUER=https://login.p.nannos.rcplus.io/realms/nannos
OIDC_CLIENT_ID=agent-runner

# Console Backend (for fetching sub-agent configs)
CONSOLE_BACKEND_URL=http://localhost:5001

# MCP Gateway (for tool execution)
MCP_GATEWAY_URL=https://alloych.gatana.ai/mcp
MCP_TIMEOUT_SECONDS=300

# Model Gateway (LiteLLM proxy) — REQUIRED. All LLM calls route through it;
# no per-provider fallback. Locally set by start-local.sh; in k8s the in-cluster service.
LLM_GATEWAY_URL=http://litellm-proxy.nannos.svc
# LLM_GATEWAY_API_KEY=sk-...

# AWS region (S3 offloading / local proxy provider). Chat + embedding model IDs and
# provider creds (Bedrock/Azure) live on the litellm-proxy pod, not here — this service
# only ever talks to the gateway alias.
AWS_BEDROCK_REGION=eu-central-1

# Checkpointer Configuration ( optional S3 offloading)
CHECKPOINT_S3_BUCKET_NAME=dev-nannos-infrastructure-agents-orchestrator-checkpoints
CHECKPOINT_AWS_REGION=eu-central-1
CHECKPOINT_TTL_DAYS=14
CHECKPOINT_COMPRESSION_ENABLED=true

# LangSmith Distributed Tracing
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_PROJECT=dev-nannos-agent-framework

# Document Store (PostgreSQL + pgvector) — shared with orchestrator
# Leave POSTGRES_HOST empty to disable the document store
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=console
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_SCHEMA=console
DOCUMENT_STORE_S3_BUCKET=dev-nannos-infrastructure-agents-files

# Object Storage Configuration
# Backend selection: 's3' (default), 's3-compatible', or 'local'
OBJECT_STORAGE_TYPE=s3
# S3-compatible endpoint (optional, for MinIO, DigitalOcean Spaces, etc.)
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# Local storage path (for OBJECT_STORAGE_TYPE=local, development only)
# LOCAL_STORAGE_PATH=./local-storage

# GCP Configuration (for Gemini models)
GCP_LOCATION=global
# NOTE: GCP_KEY must be wrapped in single quotes to preserve JSON format
# Example: GCP_KEY='{"type":"service_account",...}'
GCP_KEY='{}'
